        element={
          <ProtectedRoute>
            <BorrowedBooks />
          </ProtectedRoute>
        }
      />

      <Route
        path="/books"
        element={
          <ProtectedRoute>
            <Books />
          </ProtectedRoute>
        }
      />
    </Routes>
  )
}

export default App
</file>

