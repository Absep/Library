<file path="frontend/src/hooks/useDebounce.js">
import {
  useEffect,
  useState,
} from 'react'

function useDebounce(
  value,
  delay,
) {
  const [
    debouncedValue,
    setDebouncedValue,
  ] = useState(value)

  useEffect(() => {
    const timer =
      setTimeout(() => {
        setDebouncedValue(
          value,
        )
      }, delay)

    return () =>
      clearTimeout(
        timer,
      )
  }, [value, delay])

  return debouncedValue
}

export default useDebounce
</file>

